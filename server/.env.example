PORT=4000
JWT_SECRET=replace-with-a-long-random-string

# Database — PostgreSQL (Supabase in production; used for local dev too).
# Supabase: Project -> Connect -> ORMs/Prisma. Use the "Session pooler" or the
# direct connection string (port 5432). URL-encode any special chars in the
# password. Example:
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase Storage for visitor photos (optional). If unset, the server falls
# back to placeholder avatars so the app still works.
# From Supabase: Project Settings -> API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=visitors

# Razorpay TEST-mode keys from https://dashboard.razorpay.com (Settings -> API Keys).
# Test keys start with "rzp_test_". No business/KYC needed for test mode.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: only needed if you configure a webhook in the Razorpay dashboard.
RAZORPAY_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# AI assistant + voice (optional). Works with any OpenAI-compatible provider.
# Pick ONE of the setups below.
#
# 1) GROQ  — FREE, fast, open-source Llama for chat + Whisper for voice.
#    Get a key at https://console.groq.com (Settings -> API Keys).
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# AI_CHAT_MODEL=llama-3.3-70b-versatile
# AI_TRANSCRIBE_MODEL=whisper-large-v3
#
# 2) OLLAMA — 100% local/offline, open source, no key (voice NOT supported).
#    Install from https://ollama.com, then `ollama pull llama3.1`.
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_CHAT_MODEL=llama3.1
#
# 3) OPENAI — paid. Just set the key; defaults to gpt-4o-mini + whisper-1.
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_CHAT_MODEL=gpt-4o-mini
# AI_TRANSCRIBE_MODEL=whisper-1
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=
AI_TRANSCRIBE_MODEL=

# ------------------------------------------------------------------------------
# Email (for self-service "Forgot password" OTP codes). OPTIONAL.
# If unset, the server runs in DEV mode: the reset code is printed to the server
# console AND returned by the API so you can test without any provider.
#
# Option A) RESEND (recommended, free tier) — https://resend.com
#   Verify a domain (or use onboarding@resend.dev to send only to your own inbox).
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM=H2O <no-reply@yourdomain.com>
#
# Option B) SMTP (Gmail app password, SendGrid, Mailgun, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=H2O <you@gmail.com>
EMAIL_PROVIDER=
EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# ------------------------------------------------------------------------------
# Automated monthly backup. On the last day of each month the server emails a
# full data backup (JSON + CSV attachments) to every society admin.
# In-process schedule runs whenever the server is awake; set to "false" to disable.
BACKUP_CRON_ENABLED=true
# For hosts that sleep (e.g. Render free tier), point an EXTERNAL scheduler at
# POST /api/cron/monthly-backup with header  x-cron-secret: <CRON_SECRET>
# (cron-job.org, Render Cron Job, GitHub Actions, etc.). Set a long random value.
CRON_SECRET=
