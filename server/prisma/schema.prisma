// H2O society app database schema.
// PostgreSQL (Supabase in production). Roles/statuses are kept as plain strings
// for portability rather than DB enums.
// Allowed values:
//   User.role      : "superadmin" | "admin" | "guard" | "resident"
//   Bill.status    : "pending"  | "paid"
//   Visitor.status : "pending"  | "approved" | "rejected" | "leave_at_gate"
//
// Multi-tenancy: every society is a Society. Flats, users (admin/guard/resident),
// expenses and the bank account belong to exactly one society. Bills and visitors
// are scoped through their flat. The "superadmin" (H2O platform owner) has no
// society (societyId = null) and can see/manage every society.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Society {
  id            String           @id @default(uuid())
  name          String
  city          String?
  address       String?
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  flats         Flat[]
  users         User[]
  expenses      Expense[]
  accounts      SocietyAccount[]
  announcements Announcement[]
  posts         Post[]
}

model Flat {
  id        String    @id @default(uuid())
  society   Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId String
  flatNo    String
  block     String?
  ownerName String?
  residents User[]
  bills     Bill[]
  visitors  Visitor[]
  createdAt DateTime  @default(now())

  // Flat numbers are unique within a society (two societies may both have A-101).
  @@unique([societyId, flatNo])
  @@index([societyId])
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          String
  // Society this user belongs to. Null only for the platform superadmin.
  society       Society?  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId     String?
  flat          Flat?     @relation(fields: [flatId], references: [id])
  flatId        String?
  expoPushToken String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  // Visitors this user (a guard) logged at the gate.
  loggedVisitors Visitor[] @relation("GuardVisitors")
  // Community board posts authored by this user.
  posts         Post[]

  @@index([societyId])
}

model Bill {
  id         String    @id @default(uuid())
  flat       Flat      @relation(fields: [flatId], references: [id], onDelete: Cascade)
  flatId     String
  period     String // e.g. "2026-07"
  amount     Float
  dueDate    String // e.g. "2026-07-10"
  status     String    @default("pending")
  paidAt     DateTime?
  paymentRef String?
  orderId    String?
  // How the bill was settled: "online" (Razorpay/mock) or "cash" (recorded by admin).
  paymentMode   String?
  // For cash payments: who collected it (society member) and their phone.
  collectedBy   String?
  collectorPhone String?
  createdAt  DateTime  @default(now())

  @@index([flatId])
}

model Visitor {
  id        String    @id @default(uuid())
  flat      Flat      @relation(fields: [flatId], references: [id], onDelete: Cascade)
  flatId    String
  name      String
  phone     String?
  vehicleNo String?
  purpose   String?
  photoUrl  String?
  guard     User?     @relation("GuardVisitors", fields: [guardId], references: [id])
  guardId   String?
  status    String    @default("pending")
  decidedBy String?
  createdAt DateTime  @default(now())
  decidedAt DateTime?

  @@index([flatId])
}

model Expense {
  id        String   @id @default(uuid())
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId String
  label     String
  amount    Float
  date      DateTime @default(now())
  createdBy String?
  createdAt DateTime @default(now())

  @@index([societyId])
}

// A society's bank account that maintenance collections are routed to (one per
// society). razorpayAccountId is a Razorpay Route "Linked Account" id
// (acc_XXXXXXXX); when set, each maintenance order transfers its full amount to it.
model SocietyAccount {
  id                String   @id @default(uuid())
  society           Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId         String
  accountHolderName String
  bankName          String?
  accountNumber     String?
  ifsc              String?
  upiId             String?
  razorpayAccountId String?
  active            Boolean  @default(true)
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([societyId])
}

// Society announcements posted by admins; visible to everyone in the society.
model Announcement {
  id        String   @id @default(uuid())
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId String
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdBy String? // admin user id
  authorName String?
  createdAt DateTime @default(now())

  @@index([societyId])
}

// Community board posts by residents (sell items, queries, info). Admin can delete.
model Post {
  id         String   @id @default(uuid())
  society    Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  societyId  String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId   String
  // "general" | "sale" | "query" | "lost_found" | "recommend"
  category   String   @default("general")
  title      String
  body       String
  price      Float?
  createdAt  DateTime @default(now())

  @@index([societyId])
  @@index([authorId])
}
