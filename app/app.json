{
  "expo": {
    "name": "H2O",
    "slug": "h2o",
    "owner": "sanket2891",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0B6E8F",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.h2o.society"
    },
    "android": {
      "package": "com.h2o.society",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6E8F"
      },
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "cameraPermission": "H2O uses the camera so the gate guard can take a photo of the visitor."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "H2O uses the microphone so the gate guard can dictate visitor details."
        }
      ],
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B6E8F"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://h2o-api-5sxc.onrender.com",
      "eas": {
        "projectId": "75b8960c-eda5-41bf-a856-751342266f3b"
      }
    }
  }
}
